# .envrc — direnv integration
#
# With direnv + nix-direnv installed, `cd`-ing into this directory
# automatically enters the Nix dev shell without typing `nix-shell`.
#
# Install nix-direnv: https://github.com/nix-community/nix-direnv
#
#   # In your shell profile (~/.bashrc / ~/.zshrc):
#   eval "$(direnv hook bash)"   # or zsh / fish
#
# Then once per project:
#   direnv allow

use nix
